{
  "name": "server",
  "version": "1.0.0",
  "description": "Sherlock Server",
  "main": "dist/index.js",
  "scripts": {
    "predebug": "rimraf dist/*",
    "start": "",
    "test": "jest --watchAll=false --no-coverage  --runInBand --detectOpenHandles --forceExit",
    "test:docker": "../scripts/run-jest-docker.sh",
    "test:coverage": "jest --coverage  --runInBand --detectOpenHandles --forceExit",
    "test:check-coverage": "jest --coverage --runInBand --detectOpenHandles --forceExit --changedSince=main --coverageThreshold='{ \"global\": { \"branches\": 30, \"functions\": 30, \"lines\": 30, \"statements\": 30 } }'",
    "build": "tsc",
    "debug": "tsc-watch --onSuccess \"node --inspect=0.0.0.0:9230 ./dist/src/server.js\" --onFailure \"echo WHOOPS! Server compilation failed\""
  },
  "author": "Dr. John Murray and Others",
  "license": "ISC",
